# reg-rs runtime cache.
# Track: *.rgt (test definition), *.out (captured run output -- golden
# baseline companion to .rgt). Matches sw-cor24-ocaml convention.
# Ignore: *.tdb (transient db) and *.lock (concurrency lock).
work/reg-rs/*.tdb
work/reg-rs/*.lock

# Generated Forth output from the Tuplet emitter.
work/generated/

# OS files
.DS_Store

# Editor files
*.swp
*~
