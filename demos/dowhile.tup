# dowhile.tup -- the PoC milestone demo.
#
# A user mints `do _ while _ end` as a syntactic extension and
# uses it to count from 1 to 3. The whole construct is a
# library, not a built-in.

▪syntax do _ while _ end expand
  prim/forth "BEGIN"  _1  _2  prim/forth "0= UNTIL"

▪n ⟵ 0

do
  n ⟵ n + 1
  n prim/forth "."
  prim/forth "SPACE"
while  n < 3  end
# expected output: 1 2 3
