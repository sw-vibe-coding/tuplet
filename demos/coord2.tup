# coord2.tup -- tuple-var declaration and destructuring.

# Variant A: mint and initialize separately.
*coord2 -> (x y)        # mint a 2-output tuple variable
coord2 <- 3, 9          # store both fields at once
a, b <- coord2          # destructure into local scalars
# expected: a = 3, b = 9

# Variant B: mint and initialize in one statement.
*point2 -> (px py) <- 7, 11
px, py <- point2
# expected: px = 7, py = 11
